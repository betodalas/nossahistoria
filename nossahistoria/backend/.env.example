# ═══════════════════════════════════════════════════════
# Nossa História — Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ═══════════════════════════════════════════════════════

# ─── Banco de Dados ────────────────────────────────────
# Render → PostgreSQL → Connection String (External)
DATABASE_URL=postgresql://usuario:senha@host:5432/nossa_historia

# ─── JWT ───────────────────────────────────────────────
# Gere com: openssl rand -hex 64
JWT_SECRET=cole_aqui_uma_string_aleatoria_muito_longa

# ─── PayPal ────────────────────────────────────────────
# developer.paypal.com → My Apps & Credentials
PAYPAL_CLIENT_ID=seu_paypal_client_id
PAYPAL_CLIENT_SECRET=seu_paypal_client_secret
PAYPAL_MODE=sandbox
# Valor do plano premium (em BRL)
PREMIUM_PRICE=49.00

# ─── Cloudinary (fotos e áudio) ────────────────────────
# cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# ─── E-mail (Resend) ───────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_sua_chave_aqui

# ─── Google OAuth (opcional) ───────────────────────────
GOOGLE_CLIENT_ID=seu_google_client_id

# ─── App ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# URL da própria API (usada nos links de e-mail)
API_URL=http://localhost:3001/api

# URL do frontend (usada nos links de convite e redirecionamentos)
FRONTEND_URL=http://localhost:5173

# ─── Admin ─────────────────────────────────────────────
# Protege o endpoint POST /api/questions/seed
# Gere com: openssl rand -hex 32
ADMIN_SECRET=gere_uma_chave_aleatoria_aqui
