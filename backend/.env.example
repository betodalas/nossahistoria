# Banco de dados (Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/nossa_historia

# JWT
JWT_SECRET=sua_chave_secreta_muito_longa_aqui

# PayPal
PAYPAL_CLIENT_ID=seu_paypal_client_id
PAYPAL_CLIENT_SECRET=seu_paypal_client_secret
PAYPAL_MODE=sandbox

# Cloudinary (fotos)
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# Email (SendGrid ou Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_app

# App
PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
PREMIUM_PRICE=49.00
